<script>
/* ── LOADER ── */
let p=0;
const lNum=document.getElementById('loaderNum');
const lBar=document.getElementById('loaderBar');
const ldr=document.getElementById('loader');
const iv=setInterval(()=>{
  p+=Math.random()*4+1;
  if(p>=100){p=100;clearInterval(iv);setTimeout(()=>{ldr.classList.add('done');document.body.style.overflow='';},400)}
  lNum.textContent=Math.floor(p);
  lBar.style.width=p+'%';
},40);
document.body.style.overflow='hidden';

/* ── CURSOR ── */
const cur=document.getElementById('cur'),curR=document.getElementById('curR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
(function anim(){rx+=(mx-rx)*.13;ry+=(my-ry)*.13;
  curR.style.left=rx+'px';curR.style.top=ry+'px';
  requestAnimationFrame(anim);})();
document.querySelectorAll('a,button,.proj-card,.skill-cell,.exp-item,.research-row').forEach(el=>{
  el.addEventListener('mouseenter',()=>{curR.style.width='60px';curR.style.height='60px';curR.style.borderColor='rgba(243,115,33,.5)';});
  el.addEventListener('mouseleave',()=>{curR.style.width='40px';curR.style.height='40px';curR.style.borderColor='rgba(255,255,255,.4)';});
});

/* ── PARTICLE CANVAS ── */
const cv=document.getElementById('c');
const ctx=cv.getContext('2d');
let pts=[];
function resize(){cv.width=cv.parentElement.offsetWidth;cv.height=cv.parentElement.offsetHeight;pts=[];
  for(let i=0;i<120;i++){pts.push({x:Math.random()*cv.width,y:Math.random()*cv.height,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.5+.3,o:Math.random()*.5+.1})}}
resize();window.addEventListener('resize',resize);
(function draw(){
  ctx.clearRect(0,0,cv.width,cv.height);
  pts.forEach(p=>{
    p.x+=p.vx;p.y+=p.vy;
    if(p.x<0||p.x>cv.width)p.vx*=-1;
    if(p.y<0||p.y>cv.height)p.vy*=-1;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(243,115,33,${p.o})`;ctx.fill();
  });
  // draw faint connections
  for(let i=0;i<pts.length;i++){
    for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<100){
        ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);
        ctx.strokeStyle=`rgba(243,115,33,${.04*(1-d/100)})`;ctx.lineWidth=.5;ctx.stroke();
      }
    }
  }
  requestAnimationFrame(draw);})();

/* ── REVEAL ON SCROLL ── */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')});
},{threshold:.12});
document.querySelectorAll('.reveal-up,.reveal-left').forEach(el=>obs.observe(el));

/* ── COUNTER ANIMATION ── */
const counterObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting)return;
    const el=e.target;
    const target=+el.dataset.target;
    let cur=0;const step=target/40;
    const iv=setInterval(()=>{cur+=step;if(cur>=target){cur=target;clearInterval(iv)}
      el.textContent=Math.floor(cur)+(el.dataset.suffix||'');
    },30);
    counterObs.unobserve(el);
  });
},{threshold:.5});
document.querySelectorAll('[data-target]').forEach(el=>counterObs.observe(el));
</script>
