<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shri Sanjay I S — Aerospace Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Barlow+Condensed:wght@300;400;600;700;900&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --black:#000;
  --white:#fff;
  --orange:#f37321;
  --orange-dim:rgba(243,115,33,0.15);
  --gray:#8a8a8a;
  --gray-dim:rgba(255,255,255,0.06);
  --border:rgba(255,255,255,0.09);
  --font-display:'Bebas Neue',sans-serif;
  --font-body:'Barlow',sans-serif;
  --font-condensed:'Barlow Condensed',sans-serif;
  --font-mono:'DM Mono',monospace;
}
html{scroll-behavior:smooth;font-size:16px}
body{
  background:var(--black);
  color:var(--white);
  font-family:var(--font-body);
  font-weight:300;
  cursor:none;
  overflow-x:hidden;
}

/* ─── CURSOR ─── */
.cur{
  position:fixed;z-index:9999;pointer-events:none;
  width:10px;height:10px;background:var(--orange);border-radius:50%;
  transform:translate(-50%,-50%);transition:transform .1s;mix-blend-mode:difference;
}
.cur-ring{
  position:fixed;z-index:9998;pointer-events:none;
  width:40px;height:40px;border:1px solid rgba(255,255,255,.4);
  border-radius:50%;transform:translate(-50%,-50%);
  transition:transform .18s cubic-bezier(.25,.46,.45,.94),width .3s,height .3s,border-color .3s;
}
body:hover .cur-ring{border-color:rgba(243,115,33,.6)}

/* ─── LOADER ─── */
#loader{
  position:fixed;inset:0;z-index:9000;background:var(--black);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:4rem 5rem;transition:opacity .8s ease,visibility .8s;
}
#loader.done{opacity:0;visibility:hidden;pointer-events:none}
.loader-num{
  font-family:var(--font-display);font-size:clamp(6rem,20vw,18rem);
  line-height:1;color:var(--white);letter-spacing:-3px;
}
.loader-bar-wrap{width:100%;height:1px;background:rgba(255,255,255,.12);margin-top:2rem}
.loader-bar{height:100%;width:0%;background:var(--orange);transition:width .05s linear}
.loader-label{
  font-family:var(--font-mono);font-size:.65rem;letter-spacing:3px;
  color:var(--gray);text-transform:uppercase;margin-top:1rem;
}

/* ─── NAV ─── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.8rem 4rem;
  mix-blend-mode:difference;
}
.nav-logo{
  font-family:var(--font-condensed);font-size:1rem;font-weight:700;
  letter-spacing:4px;text-transform:uppercase;color:var(--white);
  text-decoration:none;
}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:2px;
  text-transform:uppercase;color:rgba(255,255,255,.6);text-decoration:none;
  transition:color .3s;
}
.nav-links a:hover{color:var(--white)}

/* ─── HERO ─── */
.hero{
  position:relative;min-height:100vh;display:flex;
  flex-direction:column;justify-content:flex-end;
  padding:0 4rem 5rem;overflow:hidden;
}
canvas#c{position:absolute;inset:0;width:100%;height:100%;z-index:0}
.hero-inner{position:relative;z-index:1}
.hero-eyebrow{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:4px;
  color:var(--orange);text-transform:uppercase;margin-bottom:1.5rem;
  display:flex;align-items:center;gap:1.2rem;
  opacity:0;transform:translateY(12px);
  animation:up .9s ease 1.5s forwards;
}
.hero-eyebrow::before{content:'';width:30px;height:1px;background:var(--orange)}
h1.hero-name{
  font-family:var(--font-display);
  font-size:clamp(5rem,14vw,15rem);
  line-height:.88;letter-spacing:-2px;
  color:var(--white);
  opacity:0;transform:translateY(40px);
  animation:up 1.2s cubic-bezier(.16,1,.3,1) 1.6s forwards;
}
h1.hero-name .orange{color:var(--orange)}
.hero-sub{
  display:flex;justify-content:space-between;align-items:flex-end;
  margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);
  opacity:0;transform:translateY(12px);
  animation:up .9s ease 2s forwards;
}
.hero-role{
  font-family:var(--font-condensed);font-size:1.1rem;font-weight:300;
  letter-spacing:3px;text-transform:uppercase;color:var(--gray);
  max-width:400px;line-height:1.5;
}
.hero-location{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:2px;
  color:rgba(255,255,255,.3);text-align:right;
}
.scroll-hint{
  position:absolute;right:4rem;bottom:5rem;z-index:1;
  display:flex;flex-direction:column;align-items:center;gap:.8rem;
  font-family:var(--font-mono);font-size:.55rem;letter-spacing:3px;
  color:rgba(255,255,255,.25);text-transform:uppercase;
  writing-mode:vertical-rl;
  opacity:0;animation:up .8s ease 2.2s forwards;
}
.scroll-hint::after{
  content:'';width:1px;height:50px;
  background:linear-gradient(var(--gray),transparent);
}

/* ─── MARQUEE ─── */
.marquee-wrap{
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  overflow:hidden;padding:.8rem 0;background:var(--black);position:relative;z-index:1;
}
.marquee-track{
  display:flex;gap:3rem;white-space:nowrap;
  animation:marquee 30s linear infinite;
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:3px;
  color:rgba(255,255,255,.25);text-transform:uppercase;
}
.marquee-track span{color:var(--orange)}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─── GENERIC SECTION ─── */
section{position:relative;z-index:1}
.sec-num{
  font-family:var(--font-display);font-size:clamp(5rem,10vw,9rem);
  color:rgba(255,255,255,.04);letter-spacing:-2px;line-height:1;
  margin-bottom:-2rem;display:block;
}
.sec-label{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:3px;
  color:var(--orange);text-transform:uppercase;margin-bottom:1.2rem;
}
.sec-title{
  font-family:var(--font-display);
  font-size:clamp(3rem,7vw,6.5rem);
  line-height:.95;letter-spacing:-1px;
  margin-bottom:3rem;
}

/* ─── ABOUT ─── */
#about{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:100vh;
}
.about-photo{
  position:relative;overflow:hidden;
}
.about-photo img{
  width:100%;height:100%;object-fit:cover;object-position:center top;
  filter:grayscale(20%) contrast(1.1);
  transform:scale(1.08);transition:transform 8s ease;
}
.about-photo:hover img{transform:scale(1)}
.about-photo-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to right,transparent 60%,var(--black));
}
.about-text{
  padding:8rem 5rem 6rem 4rem;
  display:flex;flex-direction:column;justify-content:center;
  background:var(--black);
}
.about-bio{
  font-size:1.15rem;font-weight:300;line-height:1.8;
  color:rgba(255,255,255,.65);margin-bottom:3rem;
}
.about-bio strong{color:var(--white);font-weight:500}
.stats-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  border:1px solid var(--border);margin-top:3rem;
}
.stat{
  padding:1.5rem;border-right:1px solid var(--border);
  text-align:center;
}
.stat:last-child{border-right:none}
.stat-n{
  font-family:var(--font-display);font-size:3.5rem;
  color:var(--orange);display:block;line-height:1;
}
.stat-l{
  font-family:var(--font-mono);font-size:.58rem;letter-spacing:2px;
  color:var(--gray);text-transform:uppercase;margin-top:.4rem;display:block;
}

/* ─── MISSION ─── */
#mission{
  padding:12rem 10vw;background:var(--black);
  display:flex;flex-direction:column;align-items:center;text-align:center;
  border-top:1px solid var(--border);
}
.mission-quote{
  font-family:var(--font-condensed);font-weight:300;font-style:italic;
  font-size:clamp(1.8rem,4.5vw,4rem);line-height:1.3;
  color:rgba(255,255,255,.75);max-width:900px;margin:2rem 0 3rem;
}
.mission-quote strong{color:var(--white);font-style:normal;font-weight:600}
.mission-quote .hl{color:var(--orange)}

/* ─── SKILLS ─── */
#skills{
  padding:8rem 4rem;background:#050505;
  border-top:1px solid var(--border);
}
.skills-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  border:1px solid var(--border);
}
.skill-cell{
  padding:2.5rem 2rem;border-right:1px solid var(--border);
  position:relative;overflow:hidden;
  transition:background .4s;
}
.skill-cell:last-child{border-right:none}
.skill-cell:hover{background:var(--gray-dim)}
.skill-cell::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:var(--orange);transform:scaleX(0);transform-origin:left;
  transition:transform .4s cubic-bezier(.25,.46,.45,.94);
}
.skill-cell:hover::after{transform:scaleX(1)}
.skill-icon{font-size:1.4rem;margin-bottom:1.5rem;display:block}
.skill-name{
  font-family:var(--font-condensed);font-size:1.1rem;font-weight:600;
  letter-spacing:2px;text-transform:uppercase;color:var(--white);
  margin-bottom:1.2rem;
}
.skill-items{display:flex;flex-direction:column;gap:.4rem}
.skill-item{
  font-family:var(--font-mono);font-size:.6rem;letter-spacing:1px;
  color:var(--gray);padding:.3rem 0;
  border-bottom:1px solid rgba(255,255,255,.04);
}

/* ─── EXPERIENCE ─── */
#experience{
  padding:8rem 4rem;border-top:1px solid var(--border);
}
.exp-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4rem}
.exp-list{display:flex;flex-direction:column}
.exp-item{
  display:grid;grid-template-columns:200px 1fr auto;gap:3rem;
  padding:2.5rem 0;border-bottom:1px solid var(--border);
  align-items:start;
  transition:background .3s;position:relative;
}
.exp-item::before{
  content:'';position:absolute;left:-4rem;right:-4rem;top:0;bottom:0;
  background:rgba(255,255,255,.02);opacity:0;transition:opacity .3s;
}
.exp-item:hover::before{opacity:1}
.exp-date{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:2px;
  color:var(--orange);padding-top:.3rem;
}
.exp-company{
  font-family:var(--font-condensed);font-size:1.8rem;font-weight:700;
  letter-spacing:1px;color:var(--white);margin-bottom:.4rem;line-height:1;
}
.exp-role{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:2px;
  color:var(--gray);text-transform:uppercase;margin-bottom:.8rem;
}
.exp-desc{
  font-size:.95rem;font-weight:300;line-height:1.7;
  color:rgba(255,255,255,.5);max-width:500px;
}
.exp-idx{
  font-family:var(--font-display);font-size:3rem;
  color:rgba(255,255,255,.06);padding-top:.2rem;
}

/* ─── PROJECTS ─── */
#projects{
  padding:8rem 4rem;background:#050505;
  border-top:1px solid var(--border);
}
.proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border)}
.proj-card{
  background:var(--black);padding:3rem;
  position:relative;overflow:hidden;
  transition:background .3s;
}
.proj-card:hover{background:#0a0a0a}
.proj-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(to right,var(--orange),transparent);
  transform:scaleX(0);transform-origin:left;
  transition:transform .5s cubic-bezier(.25,.46,.45,.94);
}
.proj-card:hover::before{transform:scaleX(1)}
.proj-n{
  font-family:var(--font-display);font-size:4rem;
  color:rgba(255,255,255,.05);margin-bottom:-1rem;display:block;
}
.proj-title{
  font-family:var(--font-condensed);font-size:1.5rem;font-weight:700;
  color:var(--white);margin-bottom:1rem;line-height:1.2;
  transition:color .3s;
}
.proj-card:hover .proj-title{color:var(--orange)}
.proj-desc{
  font-size:.9rem;font-weight:300;line-height:1.7;
  color:rgba(255,255,255,.45);margin-bottom:1.5rem;
}
.proj-tags{display:flex;flex-wrap:wrap;gap:.4rem}
.proj-tag{
  font-family:var(--font-mono);font-size:.55rem;letter-spacing:1.5px;
  color:rgba(243,115,33,.7);border:1px solid rgba(243,115,33,.2);
  padding:.2rem .6rem;
}

/* ─── RESEARCH ─── */
#research{
  padding:8rem 4rem;border-top:1px solid var(--border);
}
.research-items{display:flex;flex-direction:column;gap:0}
.research-row{
  display:flex;align-items:center;gap:3rem;
  padding:2rem 0;border-bottom:1px solid var(--border);
  transition:padding-left .3s;cursor:default;
}
.research-row:hover{padding-left:1rem;border-bottom-color:var(--orange)}
.research-row:hover .r-num{color:var(--orange)}
.r-num{
  font-family:var(--font-display);font-size:1.6rem;
  color:rgba(255,255,255,.15);min-width:3rem;
  transition:color .3s;
}
.r-title{
  font-family:var(--font-condensed);font-size:1.2rem;font-weight:400;
  color:rgba(255,255,255,.8);line-height:1.3;flex:1;
}
.r-arrow{
  font-size:1.5rem;color:rgba(255,255,255,.1);
  transition:color .3s,transform .3s;
}
.research-row:hover .r-arrow{color:var(--orange);transform:translateX(6px)}

/* ─── EVENTS ─── */
.events-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--border);margin-top:4rem;
}
.event-card{
  background:var(--black);padding:2rem;position:relative;overflow:hidden;
  transition:background .3s;
}
.event-card:hover{background:#0a0a0a}
.event-year{
  font-family:var(--font-mono);font-size:.6rem;letter-spacing:3px;
  color:var(--orange);margin-bottom:.8rem;
}
.event-name{
  font-family:var(--font-condensed);font-size:1.3rem;font-weight:700;
  color:var(--white);margin-bottom:.6rem;
}
.event-desc{
  font-size:.85rem;font-weight:300;line-height:1.6;
  color:rgba(255,255,255,.4);
}
.event-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:var(--orange);transform:scaleX(0);transform-origin:left;
  transition:transform .4s;
}
.event-card:hover::after{transform:scaleX(1)}

/* ─── AWARDS ─── */
.awards-strip{
  display:flex;flex-direction:column;gap:0;
  border:1px solid var(--border);margin-top:4rem;
}
.award-row{
  display:flex;align-items:center;gap:2rem;
  padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);
  font-size:.9rem;font-weight:300;color:rgba(255,255,255,.5);
  transition:background .2s,color .2s;
}
.award-row:last-child{border-bottom:none}
.award-row:hover{background:var(--gray-dim);color:var(--white)}
.award-icon{font-size:1.1rem;width:2rem;text-align:center;flex-shrink:0}

/* ─── VENTURES ─── */
#ventures{
  padding:8rem 4rem;background:#050505;
  border-top:1px solid var(--border);
}
.ventures-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border)}
.venture{
  background:var(--black);padding:4rem;position:relative;overflow:hidden;
  transition:background .3s;
}
.venture:hover{background:#0a0a0a}
.venture-badge{
  display:inline-block;
  font-family:var(--font-mono);font-size:.55rem;letter-spacing:3px;
  color:var(--orange);border:1px solid rgba(243,115,33,.3);
  padding:.3rem .8rem;text-transform:uppercase;margin-bottom:1.5rem;
}
.venture-name{
  font-family:var(--font-display);font-size:clamp(2.5rem,5vw,4rem);
  color:var(--white);margin-bottom:.8rem;letter-spacing:-1px;line-height:1;
}
.venture-sub{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:2px;
  color:var(--gray);text-transform:uppercase;margin-bottom:1.5rem;
}
.venture-desc{
  font-size:1rem;font-weight:300;line-height:1.7;
  color:rgba(255,255,255,.5);max-width:380px;
}

/* ─── CONTACT ─── */
#contact{
  min-height:100vh;display:flex;flex-direction:column;
  justify-content:space-between;padding:8rem 4rem 4rem;
  border-top:1px solid var(--border);
}
.contact-top{display:flex;justify-content:space-between;align-items:flex-start}
.contact-headline{
  font-family:var(--font-display);
  font-size:clamp(4rem,12vw,11rem);
  line-height:.88;letter-spacing:-2px;max-width:70%;
}
.contact-headline .orange{color:var(--orange)}
.contact-meta{
  display:flex;flex-direction:column;gap:1rem;
  padding-top:1.5rem;
}
.contact-links{
  display:flex;flex-direction:column;gap:0;
  border:1px solid var(--border);margin-top:6rem;
}
.contact-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.6rem 1.5rem;border-bottom:1px solid var(--border);
  text-decoration:none;transition:background .3s,padding-left .3s;
}
.contact-row:last-child{border-bottom:none}
.contact-row:hover{background:var(--gray-dim);padding-left:2rem}
.contact-row:hover .c-arrow{color:var(--orange);transform:translateX(6px)}
.c-type{
  font-family:var(--font-mono);font-size:.58rem;letter-spacing:3px;
  color:var(--orange);text-transform:uppercase;min-width:100px;
}
.c-val{
  font-family:var(--font-condensed);font-size:1.3rem;font-weight:400;
  color:var(--white);flex:1;padding:0 2rem;
}
.c-arrow{
  font-size:1.2rem;color:rgba(255,255,255,.2);
  transition:color .3s,transform .3s;
}
.footer-row{
  display:flex;justify-content:space-between;align-items:center;
  margin-top:5rem;padding-top:2rem;border-top:1px solid var(--border);
}
.footer-copy{
  font-family:var(--font-mono);font-size:.58rem;letter-spacing:2px;
  color:rgba(255,255,255,.2);text-transform:uppercase;
}

/* ─── ISRO BANNER ─── */
.isro-banner{
  position:relative;overflow:hidden;height:55vh;
  border-top:1px solid var(--border);
}
.isro-banner img{
  width:100%;height:100%;object-fit:cover;object-position:center 30%;
  filter:grayscale(30%) contrast(1.1) brightness(.7);
  transform:scale(1.05);transition:transform 8s ease;
}
.isro-banner:hover img{transform:scale(1)}
.isro-banner-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(0,0,0,.9) 0%,transparent 60%);
  display:flex;align-items:flex-end;padding:3rem 4rem;
}
.isro-caption-text{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:3px;
  color:rgba(255,255,255,.4);text-transform:uppercase;
  border-left:2px solid var(--orange);padding-left:1rem;
}

/* ─── ANIMATIONS ─── */
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.reveal-up{
  opacity:0;transform:translateY(30px);
  transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);
}
.reveal-up.in{opacity:1;transform:none}
.reveal-left{
  opacity:0;transform:translateX(-30px);
  transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);
}
.reveal-left.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}
.d4{transition-delay:.4s}.d5{transition-delay:.5s}.d6{transition-delay:.6s}

@media(max-width:768px){
  nav{padding:1.5rem 1.5rem}
  .hero{padding:0 1.5rem 4rem}
  h1.hero-name{font-size:4rem}
  #about{grid-template-columns:1fr}
  .about-photo{height:55vw}
  .about-text{padding:3rem 1.5rem}
  .skills-grid,.proj-grid,.ventures-grid,.events-grid{grid-template-columns:1fr}
  .skill-cell{border-right:none;border-bottom:1px solid var(--border)}
  section,#projects,#experience,#research,#ventures,#contact,#skills{padding:5rem 1.5rem}
  .exp-item{grid-template-columns:1fr;gap:1rem}
  .exp-idx{display:none}
  .contact-top{flex-direction:column;gap:2rem}
  .contact-headline{font-size:3.5rem;max-width:100%}
}
.hero { background-image: url('data:image/jpeg;base64,'); background-size: cover; background-position: center; }
.gal-panel img{transition:transform 8s ease}
.gal-panel:hover img{transform:scale(1.05)}
@media(max-width:768px){#gallery>div{grid-template-columns:1fr!important;min-height:auto!important}#gallery .gal-panel{min-height:55vw}}
</style>
</head>
<body>

